  hcm.csv
  hcm.parquet
  hcm-2-digits.json     # Dữ liệu 2 số cuối
  hcm-sparse.json       # Ma trận tần suất
  ...                   # Tương tự cho 20 đài còn lại

images/
  hcm/
    heatmap.jpg         # Bản đồ nhiệt
    top-10.jpg          # Top 10 số hay về
    distribution.jpg    # Phân phối tần suất
  ...                   # Tương tự cho các đài khác

src/
  run.py                # Chạy fetch + analyze (1 lệnh)
  backfill.py           # Fetch tất cả đài, 1 năm dữ liệu
